APP_ENV=development
FLASK_ENV=development
SECRET_KEY=change-me-to-at-least-32-random-characters
JWT_SECRET_KEY=change-me-to-a-different-32-character-secret
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hrmis_saas
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173
API_PREFIX=/api
UPLOAD_FOLDER=./uploads
MAX_CONTENT_LENGTH=10485760
TOKEN_EXPIRY_MINUTES=60
REFRESH_TOKEN_EXPIRY_DAYS=14
# Use Lax when frontend and API share the same site; use None only with HTTPS.
JWT_COOKIE_SAMESITE=Lax
# Optional shared parent domain for app.example.com and api.example.com.
JWT_COOKIE_DOMAIN=
REDIS_URL=redis://127.0.0.1:6379/0
REDIS_KEY_PREFIX=hrmis:auth
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_FAILURE_WINDOW_MINUTES=15
AUTH_LOCKOUT_MINUTES=15
AUTH_SUSPICIOUS_LOGIN_ENABLED=true
PASSWORD_RESET_TOKEN_MINUTES=30
EMAIL_VERIFICATION_TOKEN_HOURS=24
MFA_REQUIRED_ROLES=SUPER_ADMIN,CLIENT_ADMIN
MFA_CHALLENGE_MINUTES=5
MFA_MAX_CHALLENGE_ATTEMPTS=5
MFA_TOTP_ISSUER=HRMIS
MFA_TOTP_VALID_WINDOW=1
MFA_RECOVERY_CODE_COUNT=10
# Comma-separated Fernet keys; encrypt with the first and retain older keys for decryption during rotation.
MFA_ENCRYPTION_KEYS=
MFA_RECOVERY_CODE_PEPPER=
PASSWORD_RESET_URL=http://localhost:5173/reset-password
EMAIL_VERIFICATION_URL=http://localhost:5173/verify-email
# Development may use console; production validation requires smtp.
MAIL_TRANSPORT=console
MAIL_FROM=no-reply@example.com
MAIL_SMTP_HOST=127.0.0.1
MAIL_SMTP_PORT=587
MAIL_SMTP_USERNAME=
MAIL_SMTP_PASSWORD=
MAIL_SMTP_USE_TLS=true
MAIL_SMTP_TIMEOUT_SECONDS=10
# Enable only behind a trusted reverse proxy that overwrites X-Forwarded-For.
TRUST_PROXY_HEADERS=false
RATELIMIT_DEFAULT=200 per day;50 per hour
RATELIMIT_STORAGE_URI=memory://

# One-time values used only by: flask --app run.py bootstrap-admin
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=ChangeMe123!
BOOTSTRAP_ADMIN_FIRST_NAME=Platform
BOOTSTRAP_ADMIN_LAST_NAME=Administrator
